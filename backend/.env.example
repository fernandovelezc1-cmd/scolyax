# Google OAuth Configuration
# Get these from: https://console.cloud.google.com
SCOLYAX_GOOGLE_CLIENT_ID=your-google-client-id
SCOLYAX_GOOGLE_CLIENT_SECRET=your-google-client-secret
# For production: https://scolyax-production.up.railway.app/auth/google/callback
# For development: http://localhost:8000/auth/google/callback
SCOLYAX_GOOGLE_REDIRECT_URI=https://scolyax-production.up.railway.app/auth/google/callback

# Microsoft OAuth Configuration
# Get these from: https://portal.azure.com
SCOLYAX_MICROSOFT_CLIENT_ID=your-microsoft-client-id
SCOLYAX_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# For production: https://scolyax-production.up.railway.app/auth/microsoft/callback
# For development: http://localhost:8000/auth/microsoft/callback
SCOLYAX_MICROSOFT_REDIRECT_URI=https://scolyax-production.up.railway.app/auth/microsoft/callback

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,https://scolyax.vercel.app

# OAuth Configuration
SCOLYAX_REQUIRE_EDU=false
SCOLYAX_OAUTH_MODE=production

# SMTP Configuration (for email notifications)
SCOLYAX_SMTP_HOST=smtp.gmail.com
SCOLYAX_SMTP_PORT=587
SCOLYAX_SMTP_USER=your-email@gmail.com
SCOLYAX_SMTP_PASSWORD=your-app-password
SCOLYAX_SMTP_USE_TLS=true

# Supabase Configuration
# Get these from: https://app.supabase.com
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

# Frontend URL (for OAuth redirects)
SCOLYAX_FRONTEND_URL=https://scolyax.vercel.app
